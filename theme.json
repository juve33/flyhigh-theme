{
	"$schema": "https://schemas.wp.org/wp/6.9/theme.json",
	"version": 3,
	"settings": {
		"border": {
			"radius": false
		},
		"color": {
			"background": false,
			"defaultDuotone": true,
			"defaultGradients": false,
			"defaultPalette": false,
			"palette": [
				{
					"color": "#3892a3",
					"name": "Sky-Blue",
					"slug": "flyhigh-blue"
				},
				{
					"color": "#cca75b",
					"name": "Yellow",
					"slug": "flyhigh-yellow"
				},
				{
					"color": "#ffffff",
					"name": "White",
					"slug": "flyhigh-white"
				}
			]
		},
		"layout": {
			"allowEditing": true,
			"allowCustomContentAndWideSize": false,
			"contentSize": "1000px",
			"wideSize": "100%"
		},
		"position": {
			"sticky": true
		},
		"shadow": {
			"defaultPresets": false
		},
		"spacing": {
			"blockGap": false,
			"customSpacingSize": false,
			"spacingSizes": [
				{
					"name": "2X-Small",
					"size": "0.5rem",
					"slug": "flyhigh-xxs"
				},
				{
					"name": "X-Small",
					"size": "0.75rem",
					"slug": "flyhigh-xs"
				},
				{
					"name": "Small",
					"size": "1rem",
					"slug": "flyhigh-s"
				},
				{
					"name": "Medium",
					"size": "1.5rem",
					"slug": "flyhigh-m"
				},
				{
					"name": "Large",
					"size": "3rem",
					"slug": "flyhigh-l"
				},
				{
					"name": "X-Large",
					"size": "6rem",
					"slug": "flyhigh-xl"
				}
			]
		},
		"typography": {
			"defaultFontSizes": false,
			"customFontSize": false,
			"fontFamilies": [
				{
					"name": "Primary",
					"slug": "flyhigh-primary",
					"fontFamily": "'Encode Sans', sans-serif"
				},
				{
					"name": "Secondary",
					"slug": "flyhigh-secondary",
					"fontFamily": "'Baloo 2', sans-serif"
				}
			],
			"fontSizes": [
				{
					"name": "Small",
					"slug": "flyhigh-small",
					"size": "0.8rem"
				},
				{
					"name": "Medium",
					"slug": "flyhigh-medium",
					"size": "1rem"
				},
				{
					"name": "Large",
					"slug": "flyhigh-large",
					"size": "1.4rem"
				},
				{
					"name": "Extra Large",
					"slug": "flyhigh-x-large",
					"size": "2rem"
				}
			],
			"fontStyle": false,
			"fontWeight": true,
			"letterSpacing": false,
			"textDecoration": false,
			"textTransform": false
		},
		"useRootPaddingAwareAlignments": true,
		"blocks": {
			"core/button": {
				"color": {
					"background": true
				},
				"typography": {
					"textTransform": true
				}
			},
			"core/buttons": {
				"typography": {
					"textTransform": true
				}
			},
			"core/cover": {
				"color": {
					"gradients": [
						{
							"name": "Darker Overlay",
							"slug": "flyhigh-cover-darker-overlay",
							"gradient": "linear-gradient(to top, #0009, #0000)"
						}
					]
				}
			},
			"core/group": {
				"color": {
					"background": true
				},
				"dimensions": {
					"minHeight": true
				},
				"spacing": {
					"padding": true
				}
			},
			"core/heading": {
				"typography": {
					"fontWeight": true,
					"letterSpacing": true,
					"textTransform": true
				}
			},
			"core/paragraph": {
				"typography": {
					"fontStyle": true,
					"fontWeight": true,
					"textDecoration": true
				}
			}
		}
	},
	"styles": {
		"spacing": {
			"blockGap": "var:preset|spacing|flyhigh-s",
			"padding": {
				"right": "var:preset|spacing|flyhigh-s",
				"left": "var:preset|spacing|flyhigh-s"
			}
		},
		"typography": {
			"fontFamily": "var:preset|font-family|flyhigh-primary",
			"fontSize": "var:preset|font-size|flyhigh-medium",
			"fontWeight": "normal"
		},
		"blocks": {
		},
		"elements": {
			"button": {
				"border": {
					"radius": "var:preset|spacing|flyhigh-xxs"
				},
				"color": {
					"background": "var:preset|color|flyhigh-blue",
					"text": "var:preset|color|flyhigh-white"
				},
				"spacing": {
					"padding": {
						"top": "var:preset|spacing|flyhigh-xs",
						"right": "var:preset|spacing|flyhigh-m",
						"bottom": "var:preset|spacing|flyhigh-xs",
						"left": "var:preset|spacing|flyhigh-m"
					}
				},
				"typography": {
					"fontFamily": "var:preset|font-family|flyhigh-secondary",
					"fontWeight": "bold",
					"lineHeight": "1"
				},
				":hover": {
					"color": {
						"background": "var:preset|color|flyhigh-yellow"
					}
				}
			},
			"heading": {
				"typography": {
					"fontFamily": "var:preset|font-family|flyhigh-secondary"
				}
			}
		}
	},
	"templateParts": [
		{
			"area": "header",
			"name": "header",
			"title": "Header"
		},
		{
			"area": "footer",
			"name": "footer",
			"title": "Footer"
		}
	]
}