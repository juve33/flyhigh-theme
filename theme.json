{
	"$schema": "https://schemas.wp.org/wp/6.9/theme.json",
	"version": 3,
	"settings": {
		"border": {
			"radius": false
		},
		"color": {
			"defaultDuotone": true,
			"defaultGradients": true,
			"defaultPalette": false,
			"palette": [
				{
					"color": "#3892a3",
					"name": "Sky-Blue",
					"slug": "flyhigh-blue"
				},
				{
					"color": "#cca75b",
					"name": "Yellow",
					"slug": "flyhigh-yellow"
				},
				{
					"color": "#ffffff",
					"name": "White",
					"slug": "flyhigh-white"
				}
			]
		},
		"layout": {
			"allowEditing": true,
			"allowCustomContentAndWideSize": false,
			"contentSize": "1000px",
			"wideSize": "100%"
		},
		"position": {
			"sticky": true
		},
		"shadow": {
			"defaultPresets": false
		},
		"spacing": {
			"blockGap": false,
			"customSpacingSize": false,
			"spacingSizes": [
				{
					"name": "2X-Small",
					"size": "0.5rem",
					"slug": "flyhigh-xxs"
				},
				{
					"name": "X-Small",
					"size": "0.75rem",
					"slug": "flyhigh-xs"
				},
				{
					"name": "Small",
					"size": "1rem",
					"slug": "flyhigh-s"
				},
				{
					"name": "Medium",
					"size": "1.5rem",
					"slug": "flyhigh-m"
				},
				{
					"name": "Large",
					"size": "3rem",
					"slug": "flyhigh-l"
				},
				{
					"name": "X-Large",
					"size": "6rem",
					"slug": "flyhigh-xl"
				}
			]
		},
		"typography": {
			"defaultFontSizes": false,
			"customFontSize": false,
			"fontFamilies": [
				{
					"name": "Primary",
					"slug": "flyhigh-primary",
					"fontFamily": "sans-serif"
				}
			],
			"fontSizes": [
				{
					"name": "Small",
					"slug": "flyhigh-small",
					"size": "0.8rem"
				},
				{
					"name": "Medium",
					"slug": "flyhigh-medium",
					"size": "1rem"
				},
				{
					"name": "Large",
					"slug": "flyhigh-large",
					"size": "1.5rem"
				},
				{
					"name": "Extra Large",
					"slug": "flyhigh-x-large",
					"size": "2rem"
				}
			]
		},
		"useRootPaddingAwareAlignments": true,
		"blocks": {
			"core/group": {
				"dimensions": {
					"minHeight": true
				},
				"spacing": {
					"padding": true
				}
			}
		}
	},
	"styles": {
		"spacing": {
			"blockGap": "var:preset|spacing|flyhigh-s",
			"padding": {
				"right": "var:preset|spacing|flyhigh-s",
				"left": "var:preset|spacing|flyhigh-s"
			}
		},
		"typography": {
			"fontFamily": "var:preset|font-family|flyhigh-primary",
			"fontSize": "var:preset|font-size|flyhigh-medium"
		},
		"blocks": {
			"core/button": {
				"border": {
					"radius": "var:preset|spacing|flyhigh-xxs"
				},
				"spacing": {
					"padding": {
						"top": "var:preset|spacing|flyhigh-s",
						"right": "var:preset|spacing|flyhigh-m",
						"bottom": "var:preset|spacing|flyhigh-s",
						"left": "var:preset|spacing|flyhigh-m"
					}
				},
				"typography": {
					"lineHeight": "1"
				},
				"variations": {
					"buttons-compact": {
						"elements": {
							"button": {
								"spacing": {
									"padding": {
										"top": "var:preset|spacing|flyhigh-xxs",
										"right": "var:preset|spacing|flyhigh-xxs",
										"bottom": "var:preset|spacing|flyhigh-xxs",
										"left": "var:preset|spacing|flyhigh-xxs"
									}
								}
							}
						}
					}
				}
			}
		}
	},
	"templateParts": [
		{
			"area": "header",
			"name": "header",
			"title": "Header"
		},
		{
			"area": "footer",
			"name": "footer",
			"title": "Footer"
		}
	]
}